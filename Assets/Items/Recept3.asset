  id: recept3
  title: "\u0420\u0435\u0446\u0435\u043F\u0442 \u0437\u0435\u043B\u044C\u044F, \u0447.3"
  description: "\u0422\u0440\u0435\u0442\u044C\u044F \u0447\u0430\u0441\u0442\u044C
    \u0440\u0435\u0446\u0435\u043F\u0442\u0430 \u0437\u0435\u043B\u044C\u044F \u0434\u0435\u0433\u0440\u0430\u0434\u0430\u0446\u0438\u0438"
  icon: {fileID: 21300000, guid: 10cc80ce64470a443844e0dedb8a0e54, type: 3}
  canRead: 1
  note:
    title: "\u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B"
    text: "\u0421\u0438\u043D\u0438\u0439 \u043C\u0430\u0433\u0438\u0447\u0435\u0441\u043A\u0438\u0439
      \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B \u0440\u0430\u0441\u0442\u043E\u043B\u043E\u0447\u044C
      \u0432 \u0441\u0442\u0443\u043F\u0435. \u0421\u043B\u0435\u0434\u0443\u0435\u0442
      \u0431\u044B\u0442\u044C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u0435\u0435
      \u0438 \u043D\u0435 \u0432\u0434\u043E\u0445\u043D\u0443\u0442\u044C \u043F\u043E\u0440\u043E\u0448\u043E\u043A.
      \u0412 \u0447\u0438\u0441\u0442\u043E\u043C \u0432\u0438\u0434\u0435 \u043C\u043E\u0436\u0435\u0442
      \u0432\u044B\u0437\u0432\u0430\u0442\u044C \u0441\u0438\u043B\u044C\u043D\u0435\u0439\u0448\u0443\u044E
      \u044D\u0439\u0444\u043E\u0440\u0438\u044E \u0438 \u0433\u0430\u043B\u044E\u0446\u0438\u043D\u0430\u0446\u0438\u0438"
    illustrationPrefab: {fileID: 6533051906575840558, guid: 8483dd8318907d3408fe330e097c854a, type: 3}
