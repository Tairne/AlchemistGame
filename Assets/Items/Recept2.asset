  note:
    title: "\u041B\u0438\u0441\u0442\u044C\u044F"
    text: "\u0421\u0432\u0435\u0436\u0438\u0435 \u043B\u0438\u0441\u0442\u044C\u044F
      \u043A\u043E\u043B\u0435\u0443\u0441\u0430 \u043D\u0430\u0440\u0435\u0437\u0430\u0442\u044C
      \u043D\u043E\u0436\u043E\u043C. \u0412 \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E\u043C
      \u0432\u0438\u0434\u0435 \u043B\u0438\u0441\u0442\u044C\u044F \u043A\u043E\u043B\u0435\u0443\u0441\u0430
