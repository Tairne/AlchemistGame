  m_Script: {fileID: 11500000, guid: b078e9d89990ee44681996a5e892edba, type: 3}
  m_Name: Notice
  m_EditorClassIdentifier: 
  id: notice
  title: "\u0417\u0430\u043F\u0438\u0441\u043A\u0430 \u0430\u043B\u0445\u0438\u043C\u0438\u043A\u0430"
  description: "\u041A\u0430\u0436\u0435\u0442\u0441\u044F \u0430\u043B\u0445\u0438\u043C\u0438\u043A
    \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0437\u0430\u043F\u0438\u0441\u043A\u0443,
    \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u043C\u043E\u0436\u0435\u0442
    \u043C\u043D\u0435 \u043F\u043E\u043D\u044F\u0442\u044C, \u0447\u0442\u043E \u0434\u0435\u043B\u0430\u0442\u044C"
  icon: {fileID: -4468311507337160251, guid: a15945b5646387a4c8b90129c87a53dc, type: 3}
  canRead: 1
  note:
    title: "\u041C\u043E\u0435\u043C\u0443 \u0443\u0447\u0435\u043D\u0438\u043A\u0443"
    text: "\u0414\u043E\u0440\u043E\u0433\u043E\u0439 \u041A\u0430\u043A \u0442\u0430\u043C
      \u0442\u0435\u0431\u044F, \u044F \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u043B\u0441\u044F
      \u0432 \u043E\u0447\u0435\u0440\u0435\u0434\u043D\u043E\u0435 \u043F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435,
      \u0447\u0442\u043E\u0431\u044B \u0443\u0432\u0438\u0434\u0435\u0442\u044C \u0447\u0443\u0434\u0435\u0441\u0430
      \u0414\u0440\u0435\u0432\u043D\u0435\u0433\u043E \u0415\u0433\u0438\u043F\u0442\u0430.
      \u041A \u0441\u043E\u0436\u0430\u043B\u0435\u043D\u0438\u044E \u0443 \u043C\u0435\u043D\u044F
      \u043E\u0441\u0442\u0430\u043B\u0441\u044F \u043D\u0435\u0432\u044B\u043F\u043E\u043B\u043D\u0435\u043D\u043D\u044B\u0439
      \u0437\u0430\u043A\u0430\u0437 \u043D\u0430 \u0437\u0435\u043B\u044C\u0435
      \u0434\u0435\u0433\u0440\u0430\u0434\u0430\u0446\u0438\u0438 \u0438 \u0442\u044B
      \u043D\u0435 \u0432\u044B\u0439\u0434\u0435\u0448\u044C \u0438\u0437 \u044D\u0442\u043E\u0439
      \u043A\u043E\u043C\u043D\u0430\u0442\u044B, \u043F\u043E\u043A\u0430 \u043D\u0435
      \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0448\u044C \u0435\u0433\u043E.
      \u041A\u0430\u043A \u0442\u044B \u043F\u043E\u043C\u043D\u0438\u0448\u044C,
      \u044D\u0442\u043E \u0441\u0435\u043A\u0440\u0435\u0442\u043D\u044B\u0439 \u0440\u0435\u0446\u0435\u043F\u0442
      \u0438 \u044F \u0445\u0440\u0430\u043D\u044E \u0435\u0433\u043E \u0447\u0430\u0441\u0442\u0438
      \u0432 \u0442\u0440\u0451\u0445 \u0442\u0430\u0439\u043D\u0438\u043A\u0430\u0445.
      \u041A\u043B\u044E\u0447 \u043E\u0442 \u0448\u043A\u0430\u0442\u0443\u043B\u043A\u0438
      \u0442\u044B \u043D\u0430\u0439\u0434\u0451\u0448\u044C \u0432 \u043A\u043D\u0438\u0433\u0435,
      \u043A\u043E\u0442\u043E\u0440\u0443\u044E \u044F \u0447\u0438\u0442\u0430\u043B
      \u043F\u0435\u0440\u0435\u0434 \u0442\u0435\u043C, \u043A\u0430\u043A \u043E\u0442\u043F\u0440\u0430\u0432\u0438\u0442\u044C\u0441\u044F
      \u0432 \u0441\u0432\u043E\u0451 \u043F\u0440\u0438\u043A\u043B\u044E\u0447\u0435\u043D\u0438\u0435.
      \u042F \u043F\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0435\u0451 \u043D\u0430
      \u043F\u043E\u043B\u043A\u0443. \u0418\u043D\u0433\u0440\u0435\u0434\u0438\u0435\u043D\u0442\u044B
      \u0434\u043B\u044F \u0437\u0435\u043B\u044C\u044F \u0435\u0441\u0442\u044C
      \u0432 \u043A\u043B\u0430\u0434\u043E\u0432\u043E\u0439. \u041A\u0430\u0436\u0435\u0442\u0441\u044F,
      \u044F \u0437\u0430\u043F\u0438\u0441\u0430\u043B \u0433\u0434\u0435-\u0442\u043E
      \u043A\u043E\u0434, \u0447\u0442\u043E\u0431\u044B \u0442\u0443\u0434\u0430
      \u0432\u043E\u0439\u0442\u0438. \u0423\u0434\u0430\u0447\u0438 \u0441 \u044D\u0442\u0438\u043C!\n\u0422\u0432\u043E\u0439
      \u0414\u0435\u043C\u0435\u043D\u0446\u0438\u0439! "
    image: {fileID: 0}
